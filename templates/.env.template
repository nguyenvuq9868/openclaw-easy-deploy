# OpenClaw 配置文件模板
# 由 OpenClaw Easy Deploy 生成

# ============================================================================
# Gateway 配置 (必需)
# ============================================================================

# Gateway 认证 Token (64字符随机字符串)
# 自动生成，请勿手动修改
OPENCLAW_GATEWAY_TOKEN=__GATEWAY_TOKEN__

# 配置目录
OPENCLAW_CONFIG_DIR=__CONFIG_DIR__

# 工作空间目录
OPENCLAW_WORKSPACE_DIR=__WORKSPACE_DIR__

# Gateway 端口 (默认: 18789)
OPENCLAW_GATEWAY_PORT=__GATEWAY_PORT__

# Bridge 端口 (默认: 18790)
OPENCLAW_BRIDGE_PORT=__BRIDGE_PORT__

# 绑定模式: loopback (仅本机) 或 lan (局域网)
OPENCLAW_GATEWAY_BIND=lan

# ============================================================================
# AI 模型配置 (至少需要一个)
# ============================================================================

# Claude API Key
# 获取方式: https://console.anthropic.com/
CLAUDE_AI_SESSION_KEY=__CLAUDE_KEY__

# OpenAI API Key
# 获取方式: https://platform.openai.com/api-keys
OPENAI_API_KEY=__OPENAI_KEY__

# Google Gemini API Key
# 获取方式: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=__GEMINI_KEY__

# ============================================================================
# 聊天平台配置 (可选)
# ============================================================================

# WhatsApp 会话数据
WHATSAPP_SESSION_DATA=

# Telegram Bot Token
# 获取方式: 通过 @BotFather 创建 Bot
TELEGRAM_BOT_TOKEN=

# Discord Bot Token
# 获取方式: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Slack Bot Token
# 获取方式: https://api.slack.com/apps
SLACK_BOT_TOKEN=

# ============================================================================
# Docker 配置
# ============================================================================

# Docker 镜像名称
OPENCLAW_IMAGE=openclaw:local

# 沙箱模式 (0=关闭, 1=开启)
OPENCLAW_SANDBOX=0

# Docker Socket 路径
OPENCLAW_DOCKER_SOCKET=/var/run/docker.sock

# ============================================================================
# 高级配置 (可选)
# ============================================================================

# 额外的 Docker 挂载
OPENCLAW_EXTRA_MOUNTS=

# Home 卷名称
OPENCLAW_HOME_VOLUME=

# Docker APT 包
OPENCLAW_DOCKER_APT_PACKAGES=

# 扩展
OPENCLAW_EXTENSIONS=

# 允许不安全的私有 WebSocket
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=

